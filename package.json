{
  "name": "react-on-rails-rsc",
  "version": "19.2.0-rc.1",
  "description": "React Server Components support for react_on_rails Ruby gem",
  "exports": {
    "./client": {
      "node": {
        "types": "./dist/client.node.d.ts",
        "default": "./dist/client.node.js"
      },
      "browser": {
        "types": "./dist/client.browser.d.ts",
        "default": "./dist/client.browser.js"
      },
      "default": {
        "types": "./dist/client.browser.d.ts",
        "default": "./dist/client.browser.js"
      }
    },
    "./client.browser": {
      "types": "./dist/client.browser.d.ts",
      "default": "./dist/client.browser.js"
    },
    "./client.node": {
      "types": "./dist/client.node.d.ts",
      "default": "./dist/client.node.js"
    },
    "./server.node": {
      "types": "./dist/server.node.d.ts",
      "default": "./dist/server.node.js"
    },
    "./WebpackPlugin": {
      "types": "./dist/WebpackPlugin.d.ts",
      "default": "./dist/WebpackPlugin.js"
    },
    "./WebpackLoader": {
      "types": "./dist/WebpackLoader.d.ts",
      "default": "./dist/WebpackLoader.js"
    },
    "./RSCReferenceDiscoveryPlugin": {
      "types": "./dist/RSCReferenceDiscoveryPlugin.d.ts",
      "default": "./dist/RSCReferenceDiscoveryPlugin.js"
    },
    "./RspackPlugin": {
      "types": "./dist/react-server-dom-rspack/plugin.d.ts",
      "default": "./dist/react-server-dom-rspack/plugin.js"
    },
    "./RspackLoader": {
      "types": "./dist/react-server-dom-rspack/loader.d.ts",
      "default": "./dist/react-server-dom-rspack/loader.js"
    },
    "./server": {
      "types": "./dist/flight-server.d.ts",
      "react-server": {
        "workerd": "./dist/flight-server.edge.js",
        "deno": "./dist/flight-server.browser.js",
        "node": {
          "webpack": "./dist/flight-server.node.js",
          "default": "./dist/flight-server.node.js"
        },
        "edge-light": "./dist/flight-server.edge.js",
        "browser": "./dist/flight-server.browser.js"
      },
      "default": "./dist/flight-server.js"
    },
    ".": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "yarn test:rsc && yarn test:non-rsc",
    "test:rsc": "NODE_CONDITIONS=react-server jest tests/*.rsc.test.*",
    "test:non-rsc": "jest tests --testPathIgnorePatterns=\".*\\.rsc\\.test\\..*\"",
    "test:e2e": "bash scripts/e2e/run.sh",
    "test:e2e:downstream": "bash scripts/e2e/downstream.sh",
    "build": "rm -rf dist tsconfig.tsbuildinfo && yarn run tsc",
    "verify:artifacts": "bash scripts/verify-release.sh",
    "prepublishOnly": "yarn run build",
    "release": "bash scripts/release.sh",
    "release:dry-run": "bash scripts/release.sh --dry-run",
    "build-if-needed": "test -f dist/client.browser.js -a -f dist/client.node.js -a -f dist/server.node.js -a -f dist/flight-server.js -a -f dist/flight-server.browser.js -a -f dist/flight-server.edge.js -a -f dist/flight-server.node.js -a -f dist/RSCReferenceDiscoveryPlugin.js -a -f dist/RSCReferenceDiscoveryPlugin.d.ts -a -f dist/react-server-dom-rspack/plugin.js -a -f dist/react-server-dom-rspack/loader.js -a -f dist/webpack/RSCWebpackPlugin.js || (yarn run build && test -f dist/client.browser.js -a -f dist/client.node.js -a -f dist/server.node.js -a -f dist/flight-server.js -a -f dist/flight-server.browser.js -a -f dist/flight-server.edge.js -a -f dist/flight-server.node.js -a -f dist/RSCReferenceDiscoveryPlugin.js -a -f dist/RSCReferenceDiscoveryPlugin.d.ts -a -f dist/react-server-dom-rspack/plugin.js -a -f dist/react-server-dom-rspack/loader.js -a -f dist/webpack/RSCWebpackPlugin.js)",
    "prepack": "yarn run build-if-needed",
    "prepare": "yarn run build-if-needed"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@rspack/core": "^1.0.0",
    "@tsconfig/node14": "^14.1.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "css-loader": "^7.1.4",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.10.2",
    "publint": "0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "release-it": "20.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.4.3",
    "webpack": "^5.98.0"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "webpack": "^5.59.0"
  },
  "dependencies": {
    "acorn-loose": "^8.3.0",
    "neo-async": "^2.6.1",
    "react-server-dom-webpack": "^19.2.7",
    "webpack-sources": "^3.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shakacode/react_on_rails_rsc.git"
  },
  "keywords": [
    "server components",
    "rsc",
    "ruby on rails",
    "react-on-rails"
  ],
  "author": "ShakaCode",
  "license": "MIT",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
