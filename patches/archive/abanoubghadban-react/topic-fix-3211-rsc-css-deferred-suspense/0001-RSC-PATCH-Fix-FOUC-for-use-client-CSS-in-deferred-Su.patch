+                  }
+                  continue;
+                }
+                if (!file.endsWith('.js')) {
+                  continue;
+                }
+                if (file.endsWith('.hot-update.js')) {
+                  continue;
                 }
+                chunks.push(c.id, file);
+                break;
               }
             });
 
